#!/usr/bin/env bash
# rask — internal CLI for Rask Australia.
#
# Subcommands:
#   rask login                     Store an API token at ~/.config/rask/credentials.
#   rask chapters <URL>            Download a YouTube video locally, upload the
#                                  audio to /api/youtube-chapters, print chapters
#                                  to stdout.
#   rask logout                    Forget the stored token.
#   rask whoami                    Print the configured API base URL.
#   rask --help | rask <cmd> --help
#
# Environment overrides:
#   RASK_API_URL    Base URL of the rask app. Default: production Cloud Run URL.
#   RASK_TOKEN      Bearer token. Overrides the stored credentials file.
#
# Dependencies (provided by the Homebrew formula):
#   yt-dlp, jq, curl, ffmpeg
#
# ffmpeg is only used by the local-file path of `rask chapters` (to strip +
# transcode audio before upload). The YouTube path still does no client-side
# transcoding — yt-dlp emits whatever container YouTube serves and the server
# normalises.

set -euo pipefail

VERSION="0.1.5"
DEFAULT_API_URL="https://rask-561465842742.australia-southeast2.run.app"
CRED_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/rask"
CRED_FILE="$CRED_DIR/credentials"

# Script-level scratch dir for `chapters`. Kept at script scope (not local) so
# the EXIT trap can reach it after the function frame has unwound — referencing
# a `local` variable from the trap blows up under `set -u`.
RASK_TMPDIR=""

cleanup_tmpdir() {
  if [[ -n "${RASK_TMPDIR:-}" && -d "$RASK_TMPDIR" ]]; then
    rm -rf "$RASK_TMPDIR"
  fi
}
trap cleanup_tmpdir EXIT

# ---- helpers ---------------------------------------------------------------

die() { printf 'rask: %s\n' "$*" >&2; exit 1; }
log() { printf 'rask: %s\n' "$*" >&2; }

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing dependency: $1. Install with \`brew install $1\`."
}

api_url() {
  printf '%s' "${RASK_API_URL:-$DEFAULT_API_URL}"
}

load_token() {
  if [[ -n "${RASK_TOKEN:-}" ]]; then
    printf '%s' "$RASK_TOKEN"
    return 0
  fi
  if [[ -r "$CRED_FILE" ]]; then
    # File format: a single line containing the token. Tolerate trailing
    # whitespace from `pbpaste`/manual edits.
    tr -d '[:space:]' < "$CRED_FILE"
    return 0
  fi
  return 1
}

# ---- subcommands -----------------------------------------------------------

cmd_login() {
  mkdir -p "$CRED_DIR"
  chmod 700 "$CRED_DIR"
  printf 'Paste your rask API token (input hidden): ' >&2
  local token
  IFS= read -rs token
  printf '\n' >&2
  [[ -n "$token" ]] || die "empty token, aborting"
  umask 077
  printf '%s\n' "$token" > "$CRED_FILE"
  log "saved token to $CRED_FILE"
}

cmd_logout() {
  if [[ -f "$CRED_FILE" ]]; then
    rm -f "$CRED_FILE"
    log "removed $CRED_FILE"
  else
    log "no stored credentials"
  fi
}

cmd_whoami() {
  printf 'api_url:   %s\n' "$(api_url)"
  if load_token >/dev/null 2>&1; then
    printf 'token:     stored (%s)\n' "$([[ -n "${RASK_TOKEN:-}" ]] && echo "from env" || echo "from $CRED_FILE")"
  else
    printf 'token:     none — run `rask login`\n'
  fi
}

usage_chapters() {
  cat >&2 <<'EOF'
Usage: rask chapters <YOUTUBE_URL | VIDEO_PATH> [options]

The first argument can be either:
  - a YouTube/video URL (anything starting with http:// or https://). The CLI
    downloads the audio with yt-dlp and uploads it.
  - a local file path (video or audio). The CLI uses ffmpeg to strip and
    transcode to a small mono Opus track, then uploads it.

Options:
  --prompt-stdin             Read the system prompt for Claude from stdin.
  --prompt-file <PATH>       Read the system prompt from a file.
  --prompt <STRING>          Inline prompt (small prompts only).
  --copy                     Also copy chapters to the system clipboard (pbcopy).
  --keep                     Keep the downloaded/transcoded audio file on exit.
  --json                     Print the full JSON response instead of just the chapters.

Prompt sources are optional. If you omit them, the server uses its built-in
default chapter prompt (10–15 chapters, sponsor-merge rule, etc.).

Examples:
  # YouTube URL, default prompt, chapters print to terminal
  rask chapters "https://youtu.be/abc123"

  # YouTube URL, default prompt, also copy to clipboard
  rask chapters "https://youtu.be/abc123" --copy

  # Local video file
  rask chapters ~/Movies/episode-42.mov --copy

  # Local file with custom prompt from a file
  rask chapters ~/Movies/episode-42.mp4 --prompt-file ~/prompts/chapters.txt --copy

  # Custom prompt piped on stdin (heredoc-friendly)
  pbpaste | rask chapters "https://youtu.be/abc123" --prompt-stdin --copy
EOF
}

cmd_chapters() {
  local url=""
  local prompt=""
  local prompt_source=""
  local keep=0
  local json_out=0
  local do_copy=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage_chapters; return 0 ;;
      --prompt-stdin)
        [[ -z "$prompt_source" ]] || die "only one prompt source allowed"
        prompt_source="stdin"
        shift ;;
      --prompt-file)
        [[ -z "$prompt_source" ]] || die "only one prompt source allowed"
        [[ $# -ge 2 ]] || die "--prompt-file requires a path"
        prompt_source="file:$2"
        shift 2 ;;
      --prompt)
        [[ -z "$prompt_source" ]] || die "only one prompt source allowed"
        [[ $# -ge 2 ]] || die "--prompt requires a value"
        prompt="$2"
        prompt_source="inline"
        shift 2 ;;
      --copy) do_copy=1; shift ;;
      --keep) keep=1; shift ;;
      --json) json_out=1; shift ;;
      --) shift; break ;;
      -*) die "unknown flag: $1" ;;
      *)
        [[ -z "$url" ]] || die "unexpected extra argument: $1"
        url="$1"
        shift ;;
    esac
  done

  [[ -n "$url" ]] || { usage_chapters; exit 2; }

  # Strip a leading shell prompt if the user accidentally copied it along with
  # their path/URL. Matches:
  #   zsh default:  user@host dir % rest
  #   bash default: user@host:dir$  rest
  # Only rewrites when there is real content after the prompt; a bare prompt
  # falls through unchanged so the downstream "file not found" / yt-dlp error
  # still surfaces.
  if [[ "$url" =~ ^[A-Za-z0-9._-]+@[A-Za-z0-9._-]+[[:space:]][^%]*%[[:space:]]+(.+)$ ]]; then
    url="${BASH_REMATCH[1]}"
    log "stripped a leading shell prompt from input — using: $url"
  elif [[ "$url" =~ ^[A-Za-z0-9._-]+@[A-Za-z0-9._-]+:[^$]*[$][[:space:]]+(.+)$ ]]; then
    url="${BASH_REMATCH[1]}"
    log "stripped a leading shell prompt from input — using: $url"
  fi

  case "$prompt_source" in
    stdin)
      prompt="$(cat)"
      [[ -n "${prompt//[[:space:]]/}" ]] || die "prompt is empty"
      ;;
    file:*)
      local path="${prompt_source#file:}"
      [[ -r "$path" ]] || die "cannot read prompt file: $path"
      prompt="$(cat "$path")"
      [[ -n "${prompt//[[:space:]]/}" ]] || die "prompt is empty"
      ;;
    inline)
      [[ -n "${prompt//[[:space:]]/}" ]] || die "prompt is empty"
      ;;
    "")
      # No source given — server falls back to DEFAULT_CHAPTERS_PROMPT.
      prompt=""
      ;;
  esac

  # Detect input kind from the first positional. URLs are anything with an
  # http(s) scheme; everything else is treated as a path on disk. The CLI
  # intentionally doesn't accept file:// URLs — they'd just complicate the
  # branching for no gain (a path works).
  local input_kind="url"
  if [[ ! "$url" =~ ^https?:// ]]; then
    input_kind="file"
  fi

  require_cmd curl
  require_cmd jq
  if [[ "$input_kind" == "url" ]]; then
    require_cmd yt-dlp
  else
    require_cmd ffmpeg
    # Finder drags paths into Terminal with shell-special characters
    # backslash-escaped (e.g. `BudgetQ\&A`). If the user wraps the drop in
    # single quotes, those backslashes survive into $1 verbatim and the
    # literal path won't exist on disk. Recover transparently: if the
    # literal path is missing but the de-escaped version exists, use it.
    if [[ ! -e "$url" && "$url" == *\\* ]]; then
      local unescaped="${url//\\/}"
      if [[ -e "$unescaped" ]]; then
        log "removed shell-escape backslashes from path — using: $unescaped"
        url="$unescaped"
      fi
    fi
    [[ -e "$url" ]] || die "file not found: $url"
    [[ -r "$url" ]] || die "file not readable: $url"
    [[ -f "$url" ]] || die "not a regular file: $url"
  fi

  local token
  token="$(load_token)" || die "no token configured. Run \`rask login\` first."

  RASK_TMPDIR="$(mktemp -d -t rask.XXXXXX)"
  local tmp="$RASK_TMPDIR"
  if [[ "$keep" -eq 1 ]]; then
    # Suppress the EXIT cleanup by clearing the global the trap checks.
    log "keeping temp dir: $tmp"
    RASK_TMPDIR=""
  fi

  local started=$SECONDS

  local audio
  local audio_mime
  if [[ "$input_kind" == "url" ]]; then
    audio="$tmp/audio.m4a"
    audio_mime="audio/mp4"
    log "downloading audio with yt-dlp..."
    # worstaudio keeps the file small (Deepgram doesn't need quality, and the
    # endpoint caps at 32 MiB). Redirect yt-dlp output to stderr so it can't
    # contaminate stdout if the caller pipes us.
    yt-dlp \
      --no-warnings \
      --newline \
      -f worstaudio \
      -o "$audio" \
      -- "$url" \
      1>&2 \
      || die "yt-dlp failed"

    [[ -s "$audio" ]] || die "yt-dlp produced empty audio"
  else
    audio="$tmp/audio.opus"
    audio_mime="audio/opus"
    log "stripping audio with ffmpeg (24k mono Opus)..."
    # Match the server's normalisation parameters so the server-side re-encode
    # is effectively a no-op, and the upload stays well under the 32 MiB cap
    # (≈11 MB for a 60-min episode). Stream-copy isn't viable here because the
    # source codec is usually AAC/PCM at much higher bitrates.
    ffmpeg -y -hide_banner -loglevel error \
      -i "$url" \
      -vn \
      -c:a libopus -b:a 24k -ac 1 -ar 16000 \
      -application voip \
      "$audio" \
      1>&2 \
      || die "ffmpeg failed"

    [[ -s "$audio" ]] || die "ffmpeg produced empty audio"
  fi

  local size
  size=$(wc -c < "$audio" | tr -d '[:space:]')
  local size_mib
  size_mib=$(awk "BEGIN { printf \"%.1f\", $size / 1024 / 1024 }")
  log "downloaded ${size_mib} MiB in $((SECONDS - started))s"

  # Build the multipart args. We omit the prompt field entirely when none was
  # supplied — the server falls back to its built-in default chapters prompt.
  # curl's `-F "prompt=<file"` form streams the prompt from disk; this avoids
  # passing it on the argv (visible in `ps`) and sidesteps shell quoting issues.
  # For local files we ship the basename as the source label — the server only
  # echoes this in logs, never fetches it.
  local source_label
  if [[ "$input_kind" == "url" ]]; then
    source_label="$url"
  else
    source_label="file://$(basename -- "$url")"
  fi

  local curl_args=(
    -sS
    -X POST
    -H "Authorization: Bearer $token"
    -F "audio=@$audio;type=$audio_mime"
    -F "source_url=$source_label"
  )
  if [[ -n "$prompt" ]]; then
    printf '%s' "$prompt" > "$tmp/prompt.txt"
    curl_args+=(-F "prompt=<$tmp/prompt.txt")
  fi

  log "uploading ${size_mib} MiB + waiting for server (transcribe + chapters)..."

  # Run the HTTP call in the background and tick a spinner + elapsed counter
  # on stderr while it runs. We deliberately don't use `curl --progress-bar`
  # any more: it only animates during the upload phase, then goes silent for
  # the (longer) server-side wait, which is what we're trying to give feedback
  # about. A single uniform spinner across upload + server work avoids the
  # misleading "100% then nothing" gap.
  local response_file="$tmp/response.json"
  local http_code_file="$tmp/http_code"
  local req_started=$SECONDS

  ( curl "${curl_args[@]}" -o "$response_file" \
      -w '%{http_code}' "$(api_url)/api/youtube-chapters" \
      > "$http_code_file" ) &
  local curl_pid=$!

  local spinner=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
  local i=0
  while kill -0 "$curl_pid" 2>/dev/null; do
    local elapsed=$((SECONDS - req_started))
    printf "\r       %s %ds " "${spinner[i % 10]}" "$elapsed" >&2
    i=$((i + 1))
    sleep 0.2
  done
  # Clear the ticker line.
  printf "\r\033[K" >&2

  wait "$curl_pid"
  local curl_exit=$?
  local http_code=""
  [[ -f "$http_code_file" ]] && http_code=$(cat "$http_code_file")

  if [[ "$curl_exit" -ne 0 ]]; then
    die "curl failed (exit $curl_exit)"
  fi

  log "server replied after $((SECONDS - req_started))s"

  if [[ "$http_code" != "200" ]]; then
    local msg
    msg=$(jq -r '.error // "request failed"' < "$response_file" 2>/dev/null || cat "$response_file")
    die "HTTP $http_code: $msg"
  fi

  local total=$((SECONDS - started))
  log "done in ${total}s total"

  # Render the result.
  local body
  if [[ "$json_out" -eq 1 ]]; then
    body=$(cat "$response_file")
  else
    body=$(jq -r '.data.chapters' < "$response_file")
  fi

  if [[ "$do_copy" -eq 1 ]]; then
    if command -v pbcopy >/dev/null 2>&1; then
      printf '%s' "$body" | pbcopy
    elif command -v xclip >/dev/null 2>&1; then
      printf '%s' "$body" | xclip -selection clipboard
    elif command -v wl-copy >/dev/null 2>&1; then
      printf '%s' "$body" | wl-copy
    else
      die "--copy requested but no clipboard tool found (need pbcopy, xclip, or wl-copy)"
    fi
    local count
    count=$(printf '%s\n' "$body" | grep -cE '^[[:space:]]*[0-9]+:' || true)
    log "✓ chapters copied to clipboard${count:+ ($count entries)}"
  fi

  printf '%s\n' "$body"
}

# ---- dispatch --------------------------------------------------------------

usage() {
  cat >&2 <<EOF
rask $VERSION — internal CLI for Rask Australia.

Usage: rask <command> [args]

Commands:
  login        Store an API token.
  logout       Remove the stored token.
  whoami       Show current API URL and credential state.
  chapters     Generate YouTube chapter markers from a video URL or local file.
  version      Print version.
  help         Show this message.
EOF
}

main() {
  [[ $# -gt 0 ]] || { usage; exit 2; }
  local cmd="$1"; shift
  case "$cmd" in
    login)    cmd_login    "$@" ;;
    logout)   cmd_logout   "$@" ;;
    whoami)   cmd_whoami   "$@" ;;
    chapters) cmd_chapters "$@" ;;
    version|--version|-v) printf 'rask %s\n' "$VERSION" ;;
    help|--help|-h) usage ;;
    *) die "unknown command: $cmd. Try \`rask help\`." ;;
  esac
}

main "$@"
